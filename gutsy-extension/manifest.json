{
  "manifest_version": 3,
  "name": "Gutsy — Quick Log",
  "version": "1.1.0",
  "description": "Floating quick-log pill for IBS tracking. Log meals, bowel movements and symptoms from any tab — syncs to your Gutsy account.",
  "homepage_url": "https://gutsy.freedible.co.uk",
  "icons": {
    "16":  "icon-16.png",
    "48":  "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://epeckzrybiwjwxazhvrm.supabase.co/*",
    "https://gutsy.freedible.co.uk/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Gutsy",
    "default_icon": {
      "16":  "icon-16.png",
      "48":  "icon-48.png",
      "128": "icon-128.png"
    }
  }
}
